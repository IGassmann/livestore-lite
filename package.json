{
  "name": "livestore-workspace",
  "private": true,
  "workspaces": [
    "docs",
    "docs/src/content/_assets/code",
    "examples/*",
    "packages/@livestore/adapter-cloudflare",
    "packages/@livestore/adapter-web",
    "packages/@livestore/common",
    "packages/@livestore/common-cf",
    "packages/@livestore/effect-playwright",
    "packages/@livestore/framework-toolkit",
    "packages/@livestore/livestore",
    "packages/@livestore/peer-deps",
    "packages/@livestore/react",
    "packages/@livestore/sqlite-wasm",
    "packages/@livestore/sync-cf",
    "packages/@livestore/utils",
    "packages/@livestore/utils-dev",
    "packages/@livestore/wa-sqlite",
    "packages/@livestore/webmesh",
    "packages/@local/astro-tldraw",
    "packages/@local/astro-twoslash-code",
    "packages/@local/astro-twoslash-code/example",
    "packages/@local/shared",
    "scripts",
    "tests/integration",
    "tests/package-common",
    "tests/perf",
    "tests/perf-eventlog",
    "tests/sync-provider",
    "tests/wa-sqlite"
  ],
  "scripts": {
    "docs:build": "bash scripts/bin/package-task docs:build",
    "docs:build:api": "bash scripts/bin/package-task docs:build:api",
    "docs:build:diagnostics": "bash scripts/bin/package-task docs:build:diagnostics",
    "docs:build:phase:astro": "bash scripts/bin/package-task docs:build:phase:astro",
    "docs:build:phase:diagrams": "bash scripts/bin/package-task docs:build:phase:diagrams",
    "docs:build:phase:snippets": "bash scripts/bin/package-task docs:build:phase:snippets",
    "docs:deploy": "bash scripts/bin/package-task docs:deploy",
    "docs:deploy:prod": "bash scripts/bin/package-task docs:deploy:prod",
    "docs:deploy:prod:diagnostics": "bash scripts/bin/package-task docs:deploy:prod:diagnostics",
    "docs:deploy:prod:phase:build-deploy": "bash scripts/bin/package-task docs:deploy:prod:phase:build-deploy",
    "docs:deploy:prod:phase:purge": "bash scripts/bin/package-task docs:deploy:prod:phase:purge",
    "docs:deploy:prod:phase:verify": "bash scripts/bin/package-task docs:deploy:prod:phase:verify",
    "docs:dev": "bash scripts/bin/package-task docs:dev",
    "docs:search:sync:prod": "bash scripts/bin/package-task docs:search:sync:prod",
    "examples:build:src": "bash scripts/bin/package-task examples:build:src",
    "examples:deploy": "bash scripts/bin/package-task examples:deploy",
    "examples:deploy:prod": "bash scripts/bin/package-task examples:deploy:prod",
    "examples:install": "bash scripts/bin/package-task examples:install",
    "examples:test": "bash scripts/bin/package-task examples:test",
    "examples:validate-links": "bash scripts/bin/package-task examples:validate-links",
    "github:rulesets:check": "bash scripts/bin/package-task github:rulesets:check",
    "lint:check": "vp run lint:check:format && vp run lint:check:oxlint && vp run lint:check:lockfile",
    "lint:check:format": "vp fmt --check packages tests scripts docs .github",
    "lint:check:lockfile": "vp install --frozen-lockfile --ignore-scripts -- --config.confirmModulesPurge=false --config.side-effects-cache=false --config.verify-store-integrity=true --config.strict-store-pkg-content-check=true --config.package-import-method=clone-or-copy --pm-on-fail=ignore",
    "lint:check:madge": "sh -c 'madge --circular --no-spinner examples/*/src packages/*/*/src'",
    "lint:check:oxlint": "vp lint --import-plugin --deny-warnings --type-aware --tsconfig tsconfig.dev.json packages tests scripts docs .github",
    "lint:fix": "vp run lint:fix:format && vp run lint:fix:oxlint",
    "lint:fix:format": "vp fmt packages tests scripts docs .github",
    "lint:fix:oxlint": "vp lint --import-plugin --deny-warnings --fix --type-aware --tsconfig tsconfig.dev.json packages tests scripts docs .github",
    "lint:full": "vp run lint:check && vp run lint:check:madge && vp run --filter ./docs lint:check:md-imports",
    "lint:full:fix": "vp run lint:fix && vp run lint:check:madge && vp run --filter ./docs lint:check:md-imports",
    "release:changeset:check-bodies": "bash scripts/bin/package-task release:changeset:check-bodies",
    "release:changeset:check-pr": "bash scripts/bin/package-task release:changeset:check-pr",
    "release:changeset:status": "bash scripts/bin/package-task release:changeset:status",
    "release:changeset:verify-baseline": "bash scripts/bin/package-task release:changeset:verify-baseline",
    "release:changeset:version": "bash scripts/bin/package-task release:changeset:version",
    "release:devtools-artifact:certify-liveness": "bash scripts/bin/package-task release:devtools-artifact:certify-liveness",
    "release:devtools-artifact:certify-liveness:no-install": "bash scripts/bin/package-task release:devtools-artifact:certify-liveness:no-install",
    "release:devtools-artifact:publish": "bash scripts/bin/package-task release:devtools-artifact:publish",
    "release:devtools-artifact:publish:no-install": "bash scripts/bin/package-task release:devtools-artifact:publish:no-install",
    "release:devtools-artifact:repack-dryrun": "bash scripts/bin/package-task release:devtools-artifact:repack-dryrun",
    "release:devtools-artifact:repack-dryrun:no-install": "bash scripts/bin/package-task release:devtools-artifact:repack-dryrun:no-install",
    "release:devtools-artifact:verify": "bash scripts/bin/package-task release:devtools-artifact:verify",
    "release:notes:extract": "bash scripts/bin/package-task release:notes:extract",
    "release:plan": "bash scripts/bin/package-task release:plan",
    "release:snapshot": "bash scripts/bin/package-task release:snapshot",
    "release:snapshot:git-sha": "bash scripts/bin/package-task release:snapshot:git-sha",
    "release:stable:dryrun": "bash scripts/bin/package-task release:stable:dryrun",
    "release:stable:publish": "bash scripts/bin/package-task release:stable:publish",
    "source-policy": "bash scripts/bin/package-task source-policy",
    "test:integration:playwright": "vp run --filter ./tests/integration test",
    "test:integration:playwright:devtools": "vp run --filter ./tests/integration test:devtools",
    "test:integration:playwright:misc": "vp run --filter ./tests/integration test:misc",
    "test:integration:playwright:todomvc": "vp run --filter ./tests/integration test:todomvc",
    "test:integration:playwright:upload-trace": "vp run --filter ./tests/integration upload-trace",
    "test:integration:sync-provider": "vp run --filter ./tests/sync-provider test",
    "test:integration:sync-provider:cf-do-rpc-d1": "vp run --filter ./tests/sync-provider test:cf-do-rpc-d1",
    "test:integration:sync-provider:cf-do-rpc-do": "vp run --filter ./tests/sync-provider test:cf-do-rpc-do",
    "test:integration:sync-provider:cf-http-d1": "vp run --filter ./tests/sync-provider test:cf-http-d1",
    "test:integration:sync-provider:cf-http-do": "vp run --filter ./tests/sync-provider test:cf-http-do",
    "test:integration:sync-provider:cf-ws-d1": "vp run --filter ./tests/sync-provider test:cf-ws-d1",
    "test:integration:sync-provider:cf-ws-do": "vp run --filter ./tests/sync-provider test:cf-ws-do",
    "test:integration:sync-provider:mock": "vp run --filter ./tests/sync-provider test:mock",
    "test:integration:wa-sqlite": "vp run --filter ./tests/wa-sqlite test",
    "test:integration:wa-sqlite:build": "vp run --filter ./tests/wa-sqlite build",
    "test:perf": "vp run --filter ./tests/perf test",
    "test:unit": "vp test packages/@livestore packages/@local tests/package-common",
    "ts:build": "tsc --build tsconfig.dev.json",
    "ts:build-watch": "tsc --build tsconfig.dev.json --watch",
    "ts:clean": "tsc --build tsconfig.dev.json --clean",
    "ts:emit": "tsc --build tsconfig.dev.json --noCheck",
    "update-deps": "bash scripts/bin/package-task update-deps",
    "changeset": "changeset",
    "changeset:status": "changeset status",
    "changeset:version": "changeset version",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "25.3.3",
    "madge": "^8.0.0",
    "typescript": "6.0.3",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "packageManager": "pnpm@11.3.0"
}
